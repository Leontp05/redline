# ─────────────────────────────────────────────
# Redline — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.

# Database (Neon Postgres — get a free connection string at neon.tech)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-32-byte-secret-here
AUTH_SECRET=your-random-32-byte-secret-here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (create at: github.com/settings/developers → OAuth Apps → New)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# Google OAuth (create at: console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-oauth-client-secret

# Encryption key for API keys at rest (generate with: openssl rand -base64 32)
ENCRYPT_KEY=your-random-32-byte-encryption-key

# ─────────────────────────────────────────────
# LLM API (required for Simulate mode + Harden mode)
# Get these from your Z.ai dashboard or use OpenAI-compatible credentials.
# Without these, scans in Simulate mode will fail.
# ─────────────────────────────────────────────
ZAI_BASE_URL=https://internal-api.z.ai/v1
ZAI_API_KEY=your-zai-api-key
# ZAI_TOKEN=your-auth-token
# ZAI_USER_ID=your-user-id

# ─────────────────────────────────────────────
# Optional: Stripe (leave empty to run in "dev mode" — quotas still enforced)
# ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_TEAM=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─────────────────────────────────────────────
# Optional: Logging level (debug | info | warn | error)
# ─────────────────────────────────────────────
# LOG_LEVEL=info
